# Secrets
.env
.env.local

# Python virtualenv (TTS tools)
.venv-tts/
__pycache__/
*.pyc

# Generated audio (regenerable from scripts + stems)
audio/voice/ep*-stems/
audio/voice/ep*-stems-v2/
audio/voice/ep*-stems-v3/

# Final mixed masters (regenerable from sources + scripts)
audio/masters/*.mp3
audio/masters/*.wav

# Rendered video exports (regenerable)
exports/youtube-16x9/*.mp4
exports/reels-9x16/*.mp4
exports/tiktok-9x16/*.mp4

# Game prototype build artifacts
game/web-prototype/node_modules/
game/web-prototype/dist/
